---
import Container from "./Container.astro";
---

<section id="home" class="relative pt-32 pb-20 md:pt-40 md:pb-28 overflow-hidden bg-white">

    <!-- Background gradient blobs -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <div id="blob-a" class="absolute -top-40 -right-32 w-[600px] h-[600px] rounded-full bg-gradient-to-br from-indigo-100 to-violet-100 opacity-60 blur-3xl"></div>
        <div id="blob-b" class="absolute -bottom-20 -left-32 w-[500px] h-[500px] rounded-full bg-gradient-to-tr from-indigo-50 to-violet-50 opacity-70 blur-3xl"></div>
        <!-- Subtle dot grid -->
        <div class="absolute inset-0" style="background-image: radial-gradient(circle, #c7d2fe 1px, transparent 1px); background-size: 32px 32px; opacity: 0.35;"></div>
    </div>

    <Container>
        <div class="relative text-center max-w-4xl mx-auto">

            <!-- Small label -->
            <div class="reveal inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 rounded-full px-4 py-1.5 mb-8" data-delay="0">
                <span class="w-2 h-2 rounded-full bg-indigo-500 animate-pulse"></span>
                <span class="text-indigo-700 text-sm font-medium">Growth Systems for Local Businesses</span>
            </div>

            <!-- Headline -->
            <h1 class="reveal text-4xl sm:text-5xl md:text-6xl font-extrabold text-slate-900 leading-tight tracking-tight text-balance" data-delay="80">
                Websites, Ads &amp; Follow-Up Systems<br class="hidden md:block" />
                <span class="text-gradient"> Built to Grow Local Businesses</span>
            </h1>

            <!-- Subheadline -->
            <p class="reveal mt-6 text-lg md:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed text-balance" data-delay="160">
                We help local businesses turn website visitors, ad clicks, calls, and form submissions into real customers — with better websites, paid ads, CRM integrations, and automated follow-up.
            </p>

            <!-- CTA buttons -->
            <div class="reveal mt-10 flex flex-col sm:flex-row gap-4 justify-center" data-delay="240">
                <a
                    href="/#contact"
                    class="btn-gradient inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-base font-semibold text-white shadow-lg shadow-indigo-200"
                >
                    Book a Free Strategy Call
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
                <a
                    href="/#services"
                    class="inline-flex items-center justify-center px-7 py-3.5 rounded-full text-base font-semibold text-slate-700 bg-white border border-slate-200 hover:border-indigo-300 hover:text-indigo-600 transition-all duration-200 shadow-sm"
                >
                    View Services
                </a>
            </div>

            <!-- Benefit row -->
            <div class="reveal mt-12 pt-8 border-t border-slate-100 grid grid-cols-2 md:grid-cols-4 gap-6" data-delay="320">
                {[
                    { icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6", label: "More Leads" },
                    { icon: "M13 10V3L4 14h7v7l9-11h-7z", label: "Faster Follow-Up" },
                    { icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064", label: "Better Online Presence" },
                    { icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15", label: "Systems That Scale" },
                ].map(item => (
                    <div class="flex flex-col items-center gap-2">
                        <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                            </svg>
                        </div>
                        <span class="text-sm font-semibold text-slate-700">{item.label}</span>
                    </div>
                ))}
            </div>
        </div>
    </Container>
</section>

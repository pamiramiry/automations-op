---
import Container from "./Container.astro";

const problems = [
    {
        icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
        title: "Outdated or unprofessional website",
        desc: "First impressions happen online. A slow or dated website loses potential customers before they ever call.",
    },
    {
        icon: "M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5",
        title: "Ads sending traffic to weak landing pages",
        desc: "Running ads without a strong landing page is like pouring water into a leaky bucket.",
    },
    {
        icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
        title: "Leads not followed up with fast enough",
        desc: "Studies show 78% of customers buy from the first business that responds. Slow follow-up means lost revenue.",
    },
    {
        icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
        title: "Calls, forms, and messages not tracked",
        desc: "Without proper tracking, you don't know where your leads come from or which efforts are actually working.",
    },
    {
        icon: "M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2",
        title: "Everything done manually and disorganized",
        desc: "When nothing is automated, leads slip through the cracks and your team spends time on tasks a system should handle.",
    },
];
---

<section class="py-20 md:py-28 bg-slate-50">
    <Container>
        <div class="max-w-3xl mx-auto text-center mb-14 reveal">
            <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight text-balance">
                Most Local Businesses Don't Have a Traffic Problem —<br class="hidden md:block" />
                <span class="text-gradient">They Have a Conversion &amp; Follow-Up Problem</span>
            </h2>
            <p class="mt-4 text-slate-500 text-lg">
                Getting attention is only half the battle. The bigger issue is what happens after someone finds you.
            </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
            {problems.map((p, i) => (
                <div
                    class="reveal flex gap-4 bg-white border border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-md transition-shadow duration-200" data-dir="scale"
                    data-delay={String(i * 80)}
                >
                    <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d={p.icon} />
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-semibold text-slate-800 text-sm leading-snug mb-1">{p.title}</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">{p.desc}</p>
                    </div>
                </div>
            ))}

            <!-- Final closing card -->
            <div class="reveal sm:col-span-2 lg:col-span-3 bg-gradient-to-r from-indigo-600 to-violet-600 rounded-2xl p-6 text-white text-center" data-delay="400">
                <p class="font-semibold text-lg">The good news? All of these problems are fixable — with the right systems.</p>
                <a href="/#contact" class="mt-4 inline-flex items-center gap-2 bg-white/15 hover:bg-white/25 px-5 py-2.5 rounded-full text-sm font-semibold transition">
                    Let's fix yours
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
            </div>
        </div>
    </Container>
</section>

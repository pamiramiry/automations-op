---
import Container from "./Container.astro";

const services = [
    {
        icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
        title: "Website Design & Development",
        desc: "Modern, mobile-friendly websites and landing pages designed to make your business look professional and turn visitors into leads.",
        bullets: ["Local business websites", "Landing pages for ads", "Conversion-focused design", "SEO-ready structure"],
    },
    {
        icon: "M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z",
        title: "Meta & Google Ads",
        desc: "Campaign setup and lead-generation systems for Facebook, Instagram, and Google Search to bring qualified traffic to your business.",
        bullets: ["Facebook & Instagram ads", "Google Search campaigns", "Lead gen campaigns", "Ad creative & copy setup"],
    },
    {
        icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z",
        title: "CRM Setup & Integrations",
        desc: "Connect your forms, calls, bookings, and ad leads into a simple CRM so every opportunity is organized and easy to follow up with.",
        bullets: ["Lead capture forms", "CRM pipeline setup", "Booking integrations", "Email/SMS follow-up"],
    },
    {
        icon: "M13 10V3L4 14h7v7l9-11h-7z",
        title: "Business Automations",
        desc: "Automated follow-up workflows for new leads, missed calls, bookings, reminders, review requests, and more.",
        bullets: ["Missed-call text-back", "Automated lead follow-up", "Appointment reminders", "Review request workflows"],
    },
];
---

<section id="services" class="py-20 md:py-28 bg-white">
    <Container>
        <div class="max-w-2xl mx-auto text-center mb-14 reveal">
            <span class="inline-block text-indigo-600 text-sm font-semibold uppercase tracking-widest mb-3">What We Build For You</span>
            <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 leading-tight text-balance">
                Four Systems That Work Together to Grow Your Business
            </h2>
            <p class="mt-4 text-slate-500 text-lg">
                We don't sell standalone services. We build connected growth systems — websites, ads, CRM, and automation that work as one.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
            {services.map((s, i) => (
                <div
                    class="reveal group relative bg-white border border-slate-100 rounded-2xl p-7 shadow-sm hover:shadow-lg hover:border-indigo-100 transition-all duration-200" data-dir="scale"
                    data-delay={String(i * 100)}
                >
                    <div class="w-12 h-12 rounded-xl bg-indigo-50 group-hover:bg-indigo-100 flex items-center justify-center mb-5 transition-colors duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path stroke-linecap="round" stroke-linejoin="round" d={s.icon} />
                        </svg>
                    </div>
                    <h3 class="text-lg font-bold text-slate-900 mb-2">{s.title}</h3>
                    <p class="text-slate-500 text-sm leading-relaxed mb-4">{s.desc}</p>
                    <ul class="space-y-1.5">
                        {s.bullets.map(b => (
                            <li class="flex items-center gap-2 text-sm text-slate-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-500 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                                </svg>
                                {b}
                            </li>
                        ))}
                    </ul>

                    <!-- Subtle gradient accent in corner -->
                    <div aria-hidden="true" class="pointer-events-none absolute bottom-0 right-0 w-24 h-24 rounded-br-2xl bg-gradient-to-tl from-indigo-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                </div>
            ))}
        </div>
    </Container>
</section>

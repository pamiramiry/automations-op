---
import Container from "./Container.astro";

const flows = [
    {
        trigger: "Website form submitted",
        result: "Lead added to CRM instantly",
        icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2",
    },
    {
        trigger: "Ad lead comes in",
        result: "Instant text + email follow-up (within seconds)",
        icon: "M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z",
    },
    {
        trigger: "Missed call received",
        result: "Automatic text-back sent to caller",
        icon: "M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z",
    },
    {
        trigger: "Booking request received",
        result: "Confirmation + reminder workflow triggered",
        icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
    },
    {
        trigger: "Job or service completed",
        result: "Review request sent automatically",
        icon: "M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z",
    },
];
---

<section id="automations" class="py-20 md:py-28 bg-slate-900 text-white overflow-hidden relative">
    <!-- Background accent -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-gradient-to-b from-indigo-900/40 to-transparent rounded-b-full blur-3xl"></div>
        <div class="absolute bottom-0 right-0 w-80 h-80 bg-violet-900/30 rounded-full blur-3xl"></div>
    </div>

    <Container>
        <div class="relative grid lg:grid-cols-2 gap-14 items-center">

            <!-- Left: Copy -->
            <div class="reveal" data-dir="left">
                <span class="inline-block text-indigo-400 text-sm font-semibold uppercase tracking-widest mb-4">Business Automations</span>
                <h2 class="text-3xl md:text-4xl font-extrabold text-white leading-tight mb-6">
                    Stop Losing Leads Because You Follow Up Too Late
                </h2>
                <p class="text-slate-300 text-lg leading-relaxed mb-6">
                    When someone fills out a form, calls, books, or clicks your ad, the system should respond instantly. We connect your website, ads, CRM, and automations so leads are captured, organized, and followed up with automatically.
                </p>
                <p class="text-slate-400 text-sm mb-8">
                    Built using tools like Zapier, Make, n8n, GoHighLevel, and more — tailored to your business.
                </p>
                <a
                    href="/#contact"
                    class="btn-gradient inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold text-white shadow-lg shadow-indigo-900/50"
                >
                    Set Up Your Automations
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
            </div>

            <!-- Right: Automation flow -->
            <div class="reveal space-y-3" data-dir="right" data-delay="150">
                {flows.map((flow, i) => (
                    <div class="flex items-start gap-4 bg-white/5 hover:bg-white/8 border border-white/10 rounded-xl p-4 transition-colors duration-200">
                        <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-indigo-500/20 border border-indigo-500/30 flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d={flow.icon} />
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="text-sm text-slate-300">{flow.trigger}</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-indigo-400 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                                </svg>
                                <span class="text-sm font-semibold text-indigo-300">{flow.result}</span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </Container>
</section>
